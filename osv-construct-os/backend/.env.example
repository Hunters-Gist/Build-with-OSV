# Copy to `.env` for local development. Never commit real secrets.
# Production: set the same keys in Render (see repo `render.yaml` + backend README).

# --- Always required (startup validation) ---
JWT_SECRET=change-me-long-random-string

# --- Production required (NODE_ENV=production) ---
NODE_ENV=development
PORT=3001
# Comma-separated origins, no spaces; no wildcard in production
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# --- Hardening (secure production defaults: all true) ---
ENFORCE_ADMIN_AUTH=false
ENFORCE_PORTAL_TOKEN=false
ENFORCE_PORTAL_NONCE=false
ENFORCE_WEBHOOK_SECRET=false
ENFORCE_TWILIO_SIGNATURE=false

# Required when ENFORCE_PORTAL_TOKEN=true
# QUOTE_PORTAL_SECRET=

# Required when ENFORCE_WEBHOOK_SECRET=true
# WEBHOOK_SHARED_SECRET=

# --- Supabase (required when ENFORCE_ADMIN_AUTH=true for admin API + GET /api/auth/me) ---
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# --- AI (OpenRouter; ANTHROPIC_API_KEY is NOT used by this app) ---
# OPENROUTER_API_KEY=

# --- Data directory (Render: /var/lib/osv-data via DB_DIR) ---
# DB_DIR=

# --- URLs ---
# FRONTEND_URL=https://your-frontend.example.com
# PUBLIC_API_BASE_URL=https://your-backend.example.com

# --- Stripe checkout ---
# STRIPE_SECRET_KEY=

# --- Email / SMS (communications + Twilio routes) ---
# RESEND_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# TWILIO_RECORDING_EMAIL=

# --- Trello (job board sync) ---
# TRELLO_API_KEY=
# TRELLO_TOKEN=
# TRELLO_LIST_POSTED=
# TRELLO_LIST_ASSIGNED=
# TRELLO_LIST_IN_PROGRESS=
# TRELLO_LIST_COMPLETED=

# --- Live supplier pricing (optional; features degrade gracefully if unset) ---
# TAVILY_API_KEY=
# GOOGLE_MAPS_API_KEY=

# --- Portal rate limits (optional overrides) ---
# PORTAL_ACCESS_WINDOW_MS=600000
# PORTAL_ACCESS_LOCKOUT_MS=900000
# PORTAL_ACCESS_MAX_FAILS=8
