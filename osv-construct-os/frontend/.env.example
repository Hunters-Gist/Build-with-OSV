# Copy to `.env.local` for local development. Never commit real values.
# Vercel: set `VITE_API_URL` per environment to your Render backend origin.

# Backend API origin (no trailing slash). Required in production builds.
VITE_API_URL=http://127.0.0.1:3001

# Supabase client auth (required for /login)
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional: show Quote Builder pricing debug panel outside `npm run dev`
# VITE_SHOW_PRICING_DEBUG=false
